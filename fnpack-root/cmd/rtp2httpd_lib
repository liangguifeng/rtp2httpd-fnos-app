#!/bin/bash

log_msg() {
    local message="$1"

    if [ -n "${LOG_FILE:-}" ]; then
        echo "$(date '+%Y-%m-%d %H:%M:%S') - ${message}" >> "${LOG_FILE}" 2>/dev/null || true
    fi
}

write_user_error() {
    local message="$1"

    if [ -n "${TRIM_TEMP_LOGFILE:-}" ]; then
        printf "%s\n" "${message}" > "${TRIM_TEMP_LOGFILE}" 2>/dev/null || true
    else
        printf "%s\n" "${message}" >&2
    fi
}

return_with_message() {
    local message="$1"

    write_user_error "${message}"
    log_msg "ERROR: ${message}"
    return 1
}

fail_with_message() {
    local message="$1"

    write_user_error "${message}"
    log_msg "ERROR: ${message}"
    exit 1
}

run_or_fail() {
    local message="$1"
    local output
    shift

    if ! output="$("$@" 2>&1)"; then
        if [ -n "${output}" ]; then
            fail_with_message "${message}: ${output}"
        else
            fail_with_message "${message}"
        fi
    fi
}

get_service_port() {
    local value

    if [ "${wizard_port+x}" = "x" ]; then
        value="${wizard_port}"
    else
        value="5140"
    fi

    printf "%s" "${value}" | tr -d '[:space:]'
}

init_config_values() {
    local cors_default="$1"

    SERVICE_PORT="$(get_service_port)"
    CORS_ALLOW_ORIGIN="${wizard_cors_allow_origin:-${cors_default}}"
    DEFAULT_LOG_FORMAT='$client_addr [$time_iso8601] "$service_url" $service_type "$upstream_url"'
    UDP_RCVBUF_SIZE="${wizard_udp_rcvbuf_size:-524288}"
    ACCESS_LOG="${wizard_access_log:-}"
    LOG_FORMAT="${wizard_log_format:-${DEFAULT_LOG_FORMAT}}"
    HTTP_PROXY_USER_AGENT="${wizard_http_proxy_user_agent:-}"
    RTSP_USER_AGENT="${wizard_rtsp_user_agent:-}"
    RTSP_STUN_SERVER="${wizard_rtsp_stun_server:-}"
    UPSTREAM_INTERFACE_MULTICAST="${wizard_upstream_interface_multicast:-}"
    UPSTREAM_INTERFACE_FCC="${wizard_upstream_interface_fcc:-}"
    UPSTREAM_INTERFACE_RTSP="${wizard_upstream_interface_rtsp:-}"
    UPSTREAM_INTERFACE_HTTP="${wizard_upstream_interface_http:-}"
}

validate_config_values() {
    if [ -n "${SERVICE_PORT}" ] && [ "${SERVICE_PORT}" != "0" ] && ! [[ "${SERVICE_PORT}" =~ ^(6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[0-9]{1,4})$ ]]; then
        return_with_message "服务监听端口必须为空、0 或 0-65535 之间的数字"
        return $?
    fi

    if ! [[ "${UDP_RCVBUF_SIZE}" =~ ^[0-9]+$ ]] || [ "${UDP_RCVBUF_SIZE}" -lt 65536 ]; then
        return_with_message "UDP 接收缓冲区大小必须为不小于 65536 的数字"
        return $?
    fi

    return 0
}

read_global_config_value() {
    local config_file="$1"
    local key="$2"

    awk -v key="${key}" '
        /^[[:space:]]*\[/ {
            in_global = ($0 ~ /^[[:space:]]*\[global\][[:space:]]*([#;].*)?$/)
            next
        }
        in_global {
            line = $0
            sub(/^[[:space:]]+/, "", line)
            if (line == "" || line ~ /^[#;]/) {
                next
            }

            pos = index(line, "=")
            if (pos == 0) {
                next
            }

            name = substr(line, 1, pos - 1)
            value = substr(line, pos + 1)
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", name)

            if (name == key) {
                sub(/^[[:space:]]+/, "", value)
                sub(/[[:space:]]+$/, "", value)
                result = value
            }
        }
        END {
            if (result != "") {
                print result
            }
        }
    ' "${config_file}"
}

validate_external_m3u_file_access() {
    local config_file="$1"
    local external_m3u
    local file_path

    external_m3u="$(read_global_config_value "${config_file}" "external-m3u")"

    case "${external_m3u}" in
    ""|http://*|https://*)
        return 0
        ;;
    file://*)
        file_path="${external_m3u#file://}"
        if [ -z "${file_path}" ] || [ ! -r "${file_path}" ]; then
            return_with_message "外部 M3U 文件无法访问: ${file_path:-${external_m3u}}。请确认文件是否存在，并在【应用设置】中授权目录读取权限"
            return $?
        fi
        ;;
    esac

    return 0
}

generate_rtp2httpd_config() {
    local log_tag="$1"
    local cors_default="$2"
    local action="${3:-生成}"

    init_config_values "${cors_default}"
    validate_config_values || return $?

    log_msg "[${log_tag}] ${action}配置文件: $CONF_FILE"
    if ! rm -f "$CONF_FILE"; then
        return_with_message "删除旧配置文件失败: ${CONF_FILE}"
        return $?
    fi

    if ! cat > "$CONF_FILE" <<EOF
[global]
# 日志详细程度: 0=FATAL 1=ERROR 2=WARN 3=INFO 4=DEBUG
verbosity = ${wizard_verbosity:-3}

# 最大并发客户端数
maxclients = ${wizard_maxclients:-20}

# UDPxy 兼容性
udpxy = ${wizard_udpxy:-true}

# 工作进程数（默认: 1）
workers = ${wizard_workers:-1}

# 公网访问建议
# 检查 HTTP 请求的 Host 头 (默认：无)
hostname = ${wizard_hostname:-}

# 启用后，将使用 HTTP X-Forwarded-For 头作为客户端地址，用于显示在状态面板上 (默认：no)
# 并接受 X-Forwarded-Host / X-Forwarded-Proto 头作为 playlist.m3u 中的地址前缀
# 飞牛统一网关以反向代理方式访问本应用，因此默认启用
xff = ${wizard_xff:-true}

# HTTP 请求认证令牌（可选，默认: 无）
# 设置后，所有 HTTP 请求必须携带 r2h-token 查询参数，且值与此配置匹配
# 例如:
# http://server:5140/rtp/239.253.64.120:5140?fcc=10.255.14.152:15970&r2h-token=your-secret-token
# http://server:5140/player?r2h-token=your-secret-token
r2h-token = ${wizard_r2h_token:-}

# CORS 跨域请求配置（默认: 空，关闭）
# 留空关闭 CORS；设为 * 允许所有来源，或指定具体域名
cors-allow-origin = ${CORS_ALLOW_ORIGIN}

# 状态页路径（默认: /status）
status-page-path = ${wizard_status_page_path:-/status}

# 播放器页路径（默认: /player）
player-page-path = ${wizard_player_page_path:-/player}

# 统一网关公开访问前缀
app-path-prefix = ${APP_PATH_PREFIX}

# M3U 输出使用站点根相对路径（默认: false）
# 开启后，playlist.m3u 和 HTTP 代理改写后的 M3U 中不会包含 http://host 前缀
use-relative-path-in-m3u = ${wizard_use_relative_path_in_m3u:-false}

# 上游网络接口配置 (可选)
# 简单配置：只配置一个默认接口，所有流量类型都使用此接口
# 高级配置：为不同流量类型配置专用接口
# 注意：专用接口配置优先级高于默认接口
# upstream-interface-multicast = eth0  # 组播流量 (RTP/UDP)
# upstream-interface-fcc = eth1        # FCC
# upstream-interface-rtsp = eth2       # RTSP
# upstream-interface-http = eth3       # HTTP 代理
#
# 混合配置示例：默认使用 eth0，但 FCC 使用更快的 eth1
# upstream-interface = eth0
# upstream-interface-fcc = eth1
#
# 优先级：upstream-interface-{multicast,fcc,rtsp,http} > upstream-interface > 系统路由表
upstream-interface = ${wizard_upstream_interface:-enp2s0}
upstream-interface-multicast = ${UPSTREAM_INTERFACE_MULTICAST}
upstream-interface-fcc = ${UPSTREAM_INTERFACE_FCC}
upstream-interface-rtsp = ${UPSTREAM_INTERFACE_RTSP}
upstream-interface-http = ${UPSTREAM_INTERFACE_HTTP}

# 外部 M3U 配置（支持 file://, http://, https://）
# 注意：HTTP/HTTPS 需要安装 curl、uclient-fetch 或 wget 命令
external-m3u = ${wizard_external_m3u:-file://${TRIM_PKGHOME}/player-list.m3u}

# 外部 M3U 更新间隔（秒）
# 默认 7200（2 小时），设为 0 禁用自动更新
external-m3u-update-interval = ${wizard_external_m3u_update_interval:-7200}

# 组播周期性重新加入间隔（秒，默认: 0 禁用）
# 设置为正值（如 60）以周期性重新加入组播组
# 这是针对以下网络环境的兼容性解决方案：
# - 启用 IGMP snooping 的交换机在没有路由器 IGMP Query 时超时
# - 配置不当的网络设备会丢弃组播成员关系
# 推荐值: 30-120 秒（小于典型交换机超时 260 秒）
# 注意：默认禁用（0），仅在遇到组播流中断时才需要启用
# 注意：不支持 IPv6
mcast-rejoin-interval = ${wizard_mcast_rejoin_interval:-0}

# FCC 监听媒体流端口范围（可选，格式: 起始-结束，默认随机端口）
fcc-listen-port-range = ${wizard_fcc_port_range:-40000-40100}

# 缓冲池最大缓冲区数量（默认: 16384）
# 每个缓冲区 1536 字节，16384 个约占用 24MB 内存
# 增大此值以提高多客户端并发时的吞吐量，例如设置为 32768 或更高
buffer-pool-max-size = ${wizard_buffer_pool_max_size:-16384}

# UDP socket 接收缓冲区大小（默认: 524288 = 512KB）
# 作用于组播、FCC、RTSP RTP/RTCP 所有 UDP socket
# 对于 30 Mbps 的 4K IPTV 流，512KB 可提供约 140ms 的缓冲
# 增大此值以减少高带宽流的丢包
# 实际缓冲区大小可能受内核参数 net.core.rmem_max 限制
udp-rcvbuf-size = ${UDP_RCVBUF_SIZE}

# 访问日志文件路径（留空或不配置时禁用）
access-log = ${ACCESS_LOG}

# 访问日志格式（可选，nginx 风格 $变量）
# 默认: \$client_addr [\$time_iso8601] "\$service_url" \$service_type "\$upstream_url"
log-format = ${LOG_FORMAT}

# 覆盖上游 HTTP 代理请求的 User-Agent（默认: 不覆盖，透传客户端 User-Agent）
# 设置后将替换发送给 /http/ 上游服务器的客户端 User-Agent
http-proxy-user-agent = ${HTTP_PROXY_USER_AGENT}

# 上游 RTSP 请求的 User-Agent（默认: rtp2httpd/<version>）
# 当上游 RTSP 服务器要求特定 User-Agent 时可配置此项
rtsp-user-agent = ${RTSP_USER_AGENT}

# STUN 服务器用于 RTSP NAT 穿透（默认: 禁用）
# 当 RTSP 服务器仅支持 UDP 传输且客户端位于 NAT 后时，可尝试使用 STUN 进行 NAT 穿透（不保证成功）
# 格式: host:port 或 host（默认端口 3478）
rtsp-stun-server = ${RTSP_STUN_SERVER}

# 启用视频快照功能（默认: yes）
# 启用后可通过 \`snapshot=1\` 查询参数获取视频流的实时快照
video-snapshot = ${wizard_video_snapshot:-true}

# FFmpeg 可执行文件路径（默认: ffmpeg，使用系统 PATH）
# 如果 ffmpeg 不在 PATH 中或想使用特定版本，请指定完整路径
ffmpeg-path = ${wizard_ffmpeg_path:-/usr/bin/ffmpeg}

# FFmpeg 额外参数（默认: -hwaccel none）
# 这些参数在生成快照时传递给 ffmpeg
# 常用选项: -hwaccel none, -hwaccel auto, -hwaccel vaapi, -hwaccel qsv
ffmpeg-args = ${wizard_ffmpeg_args:--hwaccel none}

EOF
    then
        return_with_message "写入配置文件失败: ${CONF_FILE}"
        return $?
    fi

    if ! cat >> "$CONF_FILE" <<EOF
[bind]
# 监听统一网关转发的 Unix domain socket
${GATEWAY_SOCKET}
EOF
    then
        return_with_message "写入统一网关监听配置失败: ${CONF_FILE}"
        return $?
    fi

    if [ -n "${SERVICE_PORT}" ] && [ "${SERVICE_PORT}" != "0" ]; then
        if ! cat >> "$CONF_FILE" <<EOF

# 可选 TCP 监听端口
* ${SERVICE_PORT}
EOF
        then
            return_with_message "写入 TCP 监听端口配置失败: ${CONF_FILE}"
            return $?
        fi
    fi

    log_msg "[${log_tag}] 配置生成成功"
}
