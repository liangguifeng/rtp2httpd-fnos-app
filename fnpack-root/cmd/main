#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/script.log"
PROCESS_LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
CONF_FILE="${TRIM_PKGETC}/rtp2httpd.conf"
SOCKET_FILE="${TRIM_APPDEST}/rtp2httpd.sock"
CMD_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_FILE="${CMD_DIR}/rtp2httpd_lib"

if [ ! -r "${LIB_FILE}" ]; then
    echo "内部脚本库缺失: ${LIB_FILE}" > "${TRIM_TEMP_LOGFILE}"
    exit 1
fi

. "${LIB_FILE}" || {
    echo "内部脚本库加载失败: ${LIB_FILE}" > "${TRIM_TEMP_LOGFILE}"
    exit 1
}

# 写入程序启动命令
case "${TRIM_SYS_ARCH}" in
  arm)
    BINARY="${TRIM_APPDEST}/server/rtp2httpd-aarch64"
    ;;
  x86)
    BINARY="${TRIM_APPDEST}/server/rtp2httpd-x86_64"
    ;;
  *)
    fail_with_message "暂不支持当前架构：${TRIM_SYS_ARCH}"
    ;;
esac

start_process() {
    if status; then
        return 0
    fi

    if [ ! -x "${BINARY}" ]; then
        fail_with_message "rtp2httpd 可执行文件不存在或不可执行: ${BINARY}"
    fi

    if [ ! -r "${CONF_FILE}" ]; then
        fail_with_message "rtp2httpd 配置文件不存在或不可读: ${CONF_FILE}"
    fi

    validate_external_m3u_file_access "${CONF_FILE}" || return $?

#    run_or_fail "创建运行状态目录失败: ${TRIM_PKGVAR}" mkdir -p "${TRIM_PKGVAR}"

    log_msg "Starting process ..."
    "${BINARY}" --config "${CONF_FILE}" >> "${PROCESS_LOG_FILE}" 2>&1 &
    local pid="$!"

    if ! printf "%s" "${pid}" > "${PID_FILE}"; then
        kill "${pid}" 2>/dev/null || true
        fail_with_message "写入 PID 文件失败: ${PID_FILE}"
    fi

    sleep 1
    if ! check_process "${pid}"; then
        rm -f "${PID_FILE}"
        fail_with_message "rtp2httpd 启动后立即退出，请查看日志: ${PROCESS_LOG_FILE}"
    fi

    return 0
}

stop_process() {
    # 停止程序
    log_msg "Stopping process ..."
    if [ -r "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')

        # 获取 pid
        log_msg "pid=${pid}"
        if ! check_process "${pid}"; then
            # 程序不存在，删除 pid 文件
            rm -f "${PID_FILE}"
            log_msg "remove pid file 1"
        else
            log_msg "send TERM signal to PID:${pid}..."
            if ! kill -TERM "${pid}" >> "${LOG_FILE}" 2>&1; then
                fail_with_message "停止 rtp2httpd 失败，无法发送 TERM 信号到 PID ${pid}"
            fi

            # 等待程序退出
            local count=0
            while check_process "${pid}" && [ $count -lt 10 ]; do
                sleep 1
                count=$((count + 1))
                log_msg "waiting process terminal... (${count}s/10s)"
            done

            if check_process "${pid}"; then
                log_msg "send KILL signal to PID:${pid}..."
                if ! kill -KILL "${pid}" >> "${LOG_FILE}" 2>&1; then
                    fail_with_message "停止 rtp2httpd 失败，无法发送 KILL 信号到 PID ${pid}"
                fi
                sleep 1
                rm -f "${PID_FILE}"
            else
                log_msg "process killed... "
            fi
        fi
    fi

    if [ -S "${SOCKET_FILE}" ]; then
        run_or_fail "删除旧 Unix socket 文件失败: ${SOCKET_FILE}" rm -f "${SOCKET_FILE}"
        log_msg "remove socket file ${SOCKET_FILE}"
    fi

    return 0
}

check_process() {
    local pid=$1
    if kill -0 "${pid}" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

status() {
    if [ -f "${PID_FILE}" ]; then
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if check_process "${pid}"; then
            return 0
        else
            # 进程没有运行，pid 文件存在，则删除
            rm -f "${PID_FILE}"
        fi
    fi

    return 1
}

case $1 in
start)
    # 运行启动命令。成功则退出0，失败则退出1
    start_process
    ;;
stop)
    # 运行停止命令。成功则退出0，失败则退出1
    stop_process
    ;;
status)
    # 检查应用程序状态命令。如果运行则退出 0，如果不运行则退出 3
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
*)
    fail_with_message "未知服务命令: ${1:-}"
    ;;
esac
