[
  {
    "stepTitle": "说明",
    "items": [
      {
        "type": "tips",
        "helpText": "保存前请确认 <b>【服务监听端口】</b>、<b>【默认上游接口】</b> 两项配置正确。"
      }
    ]
  },
  {
    "stepTitle": "基础设置",
    "items": [
      {
        "type": "tips",
        "helpText": "以下为常用配置，多数场景保持默认即可。"
      },
      {
        "type": "text",
        "field": "wizard_port",
        "label": "服务监听端口",
        "initValue": "5140",
        "rules": [
          {
            "pattern": "^$|^(6553[0-5]|655[0-2][0-9]|65[0-4][0-9]{2}|6[0-4][0-9]{3}|[1-5][0-9]{4}|[0-9]{1,4})$",
            "message": "端口号可留空，或填写 0-65535 范围内的数字"
          }
        ]
      },
      {
        "type": "tips",
        "helpText": "服务监听端口留空或填写 0 时，只能通过飞牛统一网关访问，不开放 TCP 端口。"
      },
      {
        "type": "switch",
        "field": "wizard_udpxy",
        "label": "UDPxy 兼容模式",
        "initValue": "true"
      },
      {
        "type": "text",
        "field": "wizard_upstream_interface",
        "label": "默认上游接口",
        "initValue": "enp2s0",
        "rules": [
          {
            "required": true,
            "message": "请输入默认上游接口"
          },
          {
            "pattern": "^[a-zA-Z0-9_\\-.:]+$",
            "message": "上游网络接口只能包含字母、数字、下划线、短横线、点号和冒号"
          }
        ]
      }
    ]
  },
  {
    "stepTitle": "播放源配置",
    "items": [
      {
        "type": "tips",
        "helpText": "配置 IPTV 播放列表来源（M3U）。"
      },
      {
        "type": "text",
        "field": "wizard_external_m3u",
        "label": "外部 M3U 地址（支持 file://、http://、https://）",
        "initValue": "",
        "rules": [
          {
            "pattern": "^(http|https|file)://.+$",
            "message": "必须为 http://、https:// 或 file:// 格式"
          }
        ]
      },
      {
        "type": "text",
        "field": "wizard_external_m3u_update_interval",
        "label": "外部 M3U 自动更新间隔（秒）",
        "initValue": "7200",
        "rules": [
          {
            "pattern": "^[0-9]+$",
            "message": "必须为数字"
          }
        ]
      },
      {
        "type": "switch",
        "field": "wizard_use_relative_path_in_m3u",
        "label": "M3U 输出使用相对路径",
        "initValue": "true"
      },
      {
        "type": "tips",
        "helpText": "开启后，playlist.m3u 和 HTTP 代理改写后的 M3U 使用以 / 或应用访问前缀开头的路径，不包含协议、主机名和端口。"
      }
    ]
  },
  {
    "stepTitle": "视频快照与 FFmpeg（高级）",
    "items": [
      {
        "type": "tips",
        "helpText": "仅在需要视频截图功能时配置；一般场景可保持默认。"
      },
      {
        "type": "switch",
        "field": "wizard_video_snapshot",
        "label": "启用视频快照",
        "initValue": "true"
      },
      {
        "type": "text",
        "field": "wizard_ffmpeg_path",
        "label": "FFmpeg 可执行文件路径",
        "initValue": "/usr/bin/ffmpeg"
      },
      {
        "type": "text",
        "field": "wizard_ffmpeg_args",
        "label": "FFmpeg 额外参数",
        "initValue": "-hwaccel none"
      }
    ]
  },
  {
    "stepTitle": "访问与安全",
    "items": [
      {
        "type": "tips",
        "helpText": "如需公网访问，请仔细配置本页选项。"
      },
      {
        "type": "text",
        "field": "wizard_hostname",
        "label": "HTTP Host 头校验",
        "initValue": ""
      },
      {
        "type": "switch",
        "field": "wizard_xff",
        "label": "启用 X-Forwarded-For",
        "initValue": "true"
      },
      {
        "type": "text",
        "field": "wizard_cors_allow_origin",
        "label": "CORS 允许来源",
        "initValue": ""
      },
      {
        "type": "password",
        "field": "wizard_r2h_token",
        "label": "HTTP 请求认证令牌 (r2h-token)",
        "initValue": ""
      },
      {
        "type": "text",
        "field": "wizard_status_page_path",
        "label": "状态页面与 API 根路径",
        "initValue": "/status"
      },
      {
        "type": "text",
        "field": "wizard_player_page_path",
        "label": "内置播放器页面路径",
        "initValue": "/player"
      }
    ]
  },
  {
    "stepTitle": "性能与稳定性",
    "items": [
      {
        "type": "tips",
        "helpText": "以下配置适合多客户端或网络不稳定环境；一般场景可保持默认。"
      },
      {
        "type": "text",
        "field": "wizard_maxclients",
        "label": "最大并发客户端数",
        "initValue": "20",
        "rules": [
          {
            "pattern": "^[1-9][0-9]*$",
            "message": "必须为正整数"
          }
        ]
      },
      {
        "type": "text",
        "field": "wizard_workers",
        "label": "工作进程数",
        "initValue": "1",
        "rules": [
          {
            "pattern": "^[1-9][0-9]*$",
            "message": "必须为正整数"
          }
        ]
      },
      {
        "type": "text",
        "field": "wizard_buffer_pool_max_size",
        "label": "缓冲池最大缓冲区数量",
        "initValue": "16384",
        "rules": [
          {
            "pattern": "^[0-9]+$",
            "message": "必须为数字"
          }
        ]
      },
      {
        "type": "switch",
        "field": "wizard_zerocopy_on_send",
        "label": "启用零拷贝发送",
        "initValue": "false"
      },
      {
        "type": "text",
        "field": "wizard_fcc_port_range",
        "label": "FCC UDP 监听端口范围",
        "initValue": "40000-40100"
      },
      {
        "type": "text",
        "field": "wizard_mcast_rejoin_interval",
        "label": "组播周期性重新加入间隔（秒）",
        "initValue": "0"
      }
    ]
  }
]
